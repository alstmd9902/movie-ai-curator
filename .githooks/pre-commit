#!/bin/sh
# 커밋 전 자동 실행되는 체크 스크립트

set -e  # 하나라도 실패하면 커밋 중단

STASH_CREATED=0

restore_unstaged_changes() {
  if [ "$STASH_CREATED" -eq 1 ]; then
    echo ""
    echo "↩️  숨겨둔 unstaged 변경사항 복원 중..."
    git stash pop -q
  fi
}

trap restore_unstaged_changes EXIT INT TERM

# partial commit 시 현재 워킹트리가 아니라 staged snapshot만 검사한다.
if ! git diff --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo ""
  echo "📦 unstaged 변경사항을 잠시 숨기고 staged 파일 기준으로 검사합니다..."
  git stash push --keep-index --include-untracked -q -m "pre-commit unstaged backup"
  STASH_CREATED=1
fi

echo ""
echo "🔍 [1/3] 타입 체크 중..."
pnpm exec tsc -b --noEmit
echo "✅ 타입 체크 통과"

echo ""
echo "🔍 [2/3] 린트 체크 중..."
pnpm lint
echo "✅ 린트 통과"

echo ""
echo "📋 [3/3] docs 동기화 체크..."
STAGED_CODE_FILES="$(git diff --cached --name-only -- 'src/**' 'package.json' 'pnpm-lock.yaml' '.env.example' 'vite.config.*' 'tsconfig*.json')"
STAGED_DOC_FILES="$(git diff --cached --name-only -- 'docs/**' 'README.md' 'AGENTS.md' 'CLAUDE.md')"

if [ -n "$STAGED_CODE_FILES" ] && [ -z "$STAGED_DOC_FILES" ]; then
  echo ""
  echo "⚠️  코드/설정 변경이 staged 되었지만 관련 문서 변경이 없습니다."
  echo ""
  echo "필요하면 변경한 코드에 맞게 docs/ 문서를 별도 작업으로 업데이트하세요."
  echo ""
  echo "  | 코드 변경           | 업데이트할 문서                       |"
  echo "  | 새 페이지 추가      | docs/project.md, docs/progress.md     |"
  echo "  | 새 폴더 생성        | docs/engineering.md, docs/progress.md |"
  echo "  | 새 패키지 설치      | docs/engineering.md, docs/progress.md |"
  echo "  | 기능 완성           | docs/progress.md                      |"
  echo "  | 환경변수 추가       | docs/engineering.md                   |"
  echo ""
  echo "문서 동기화 체크는 경고만 출력하고 커밋은 계속 진행합니다."
  echo ""
else
  echo "✅ docs 동기화 확인 완료"
fi

echo ""
